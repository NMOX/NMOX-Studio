<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.nmox</groupId>
    <artifactId>NMOX-Studio-parent</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>NMOX-Studio-parent</name>

    <repositories>
        <repository>
            <id>netbeans</id>
            <name>NetBeans</name>
            <url>https://netbeans.osuosl.org/content/repositories/releases/</url>
        </repository>
    </repositories>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.netbeans.utilities</groupId>
                    <artifactId>nbm-maven-plugin</artifactId>
                    <version>14.5</version>
                    <extensions>true</extensions>
                    <configuration>
                        <brandingToken>${brandingToken}</brandingToken>
                        <cluster>${brandingToken}</cluster>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.15.0</version>
                    <configuration>
                        <source>${maven.compiler.source}</source>
                        <target>${maven.compiler.target}</target>
                        <release>${maven.compiler.target}</release>
                        <encoding>${project.build.sourceEncoding}</encoding>
                        <showWarnings>true</showWarnings>
                        <showDeprecation>true</showDeprecation>
                        <compilerArgs>
                            <arg>-Xlint:all</arg>
                            <arg>-Xlint:-processing</arg>
                            <!-- JDK 23+ defaults to -proc:none; NetBeans annotations
                                 (@TopComponent.Registration, @ServiceProvider, @Messages)
                                 need processing to generate layer/service registrations -->
                            <arg>-proc:full</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.5.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.6</version>
                <configuration>
                    <useModulePath>false</useModulePath>
                    <!-- Run the unit suite headless so it matches CI and never
                         pops a real Swing dialog (e.g. a workspace-trust prompt)
                         onto the developer's screen mid-build. -->
                    <systemPropertyVariables>
                        <java.awt.headless>true</java.awt.headless>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
            </plugins>
        </pluginManagement>
        <plugins>
            <plugin>
                <groupId>org.apache.netbeans.utilities</groupId>
                <artifactId>nbm-maven-plugin</artifactId>
                <extensions>true</extensions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <!-- Static analysis: bytecode-based, so it runs after compile and
                 never interferes with the load-bearing -proc:full annotation
                 processing. Bound to verify, so CI's `mvn -B verify` gates on
                 it. Tuned to high-confidence correctness via the exclude filter. -->
            <plugin>
                <groupId>com.github.spotbugs</groupId>
                <artifactId>spotbugs-maven-plugin</artifactId>
                <version>4.10.2.0</version>
                <configuration>
                    <effort>Max</effort>
                    <threshold>Medium</threshold>
                    <failOnError>true</failOnError>
                    <excludeFilterFile>${maven.multiModuleProjectDirectory}/config/spotbugs-exclude.xml</excludeFilterFile>
                    <!-- security detectors: command injection, path traversal,
                         SSRF, weak crypto/random, XXE — the threat surface of an
                         IDE that spawns processes, calls cloud APIs and parses
                         untrusted files -->
                    <plugins>
                        <plugin>
                            <groupId>com.h3xstream.findsecbugs</groupId>
                            <artifactId>findsecbugs-plugin</artifactId>
                            <version>1.14.0</version>
                        </plugin>
                    </plugins>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!-- Coverage measurement, wired into the test run. -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.15</version>
                <!--
                  Coverage is measured on the TESTABLE surface. These classes are
                  pure Swing rendering/layout/event-wiring with no branchable
                  business logic — they cannot be unit-tested without a live
                  windowing system, and the real logic they delegate to lives in
                  service/model classes that ARE tested. Excluding them at the
                  instrumentation level keeps both the report and the coverage
                  floor honest: every name here is a deliberate, reviewed
                  exclusion (mirrors config/spotbugs-exclude.xml's discipline),
                  not a way to dodge a number. Widgets (Knob/Led/VuMeter/…) are
                  NOT excluded — their model logic is tested; only their paint()
                  stays uncovered, absorbed by the bundle floor.
                -->
                <configuration>
                    <excludes>
                        <!-- Dockable windows and modal dialogs (NetBeans window system) -->
                        <exclude>**/*TopComponent.class</exclude>
                        <exclude>**/*TopComponent$*.class</exclude>
                        <exclude>**/*Dialog.class</exclude>
                        <exclude>**/*Dialog$*.class</exclude>
                        <!-- core: first-run editor-theme installer (FontColorSettings glue) -->
                        <exclude>**/TerminalPhosphor.class</exclude>
                        <!-- editor: Navigator tree panel + LSP status table panel -->
                        <exclude>**/StructureNavigatorPanel*.class</exclude>
                        <exclude>**/LanguageServersPanel*.class</exclude>
                        <!-- tools: New Web Project wizard visual + iterator glue -->
                        <exclude>**/WebProjectWizardPanelVisual*.class</exclude>
                        <exclude>**/WebProjectWizardIterator*.class</exclude>
                        <!-- rack: the rack canvas, file tree, and palette list + renderer -->
                        <exclude>**/RackPanel.class</exclude>
                        <exclude>**/RackPanel$*.class</exclude>
                        <exclude>**/FileTreePanel*.class</exclude>
                        <exclude>**/PalettePanel*.class</exclude>
                        <!-- infra: property sheet, node-graph canvas, palette cell renderer -->
                        <exclude>**/PropertyPanel*.class</exclude>
                        <exclude>**/FlowCanvas*.class</exclude>
                        <exclude>**/InfraPalette$Renderer.class</exclude>
                        <!-- ui: main window shell + welcome launchpad screen -->
                        <exclude>**/MainWindow*.class</exclude>
                        <exclude>**/WelcomeScreen*.class</exclude>
                        <!-- ui: menu actions that only open a dialog/file-chooser and
                             delegate to logic tested in rack (PwaKit/Experiments/
                             EnvironmentDoctor are rack classes with their own tests).
                             These seven carry no testable branch of their own. The
                             actions that DO hold ui-resident logic (StandardsKitAction's
                             validate gate, NewLearningSpaceAction/SwitchProjectAction's
                             filter predicates, GeneralOptionsPanelController, UpdateCheck)
                             are kept and tested. -->
                        <exclude>**/ui/actions/PwaKitAction*.class</exclude>
                        <exclude>**/ui/actions/ManageExperimentsAction*.class</exclude>
                        <exclude>**/ui/actions/EnvironmentDoctorAction*.class</exclude>
                        <exclude>**/ui/actions/NewExperimentAction*.class</exclude>
                        <exclude>**/ui/actions/OpenFileAction*.class</exclude>
                        <exclude>**/ui/actions/OpenFolderAction*.class</exclude>
                        <exclude>**/ui/actions/NewProjectAction*.class</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <modules>
        <module>branding</module>
        <module>core</module>
        <module>ui</module>
        <module>editor</module>
        <module>project</module>
        <module>tools</module>
        <module>rack</module>
        <module>infra</module>
        <module>apiclient</module>
        <module>application</module>
        <module>NMOX-Studio-sample</module>
    </modules>

    <properties>
        <netbeans.version>RELEASE300</netbeans.version>
        <brandingToken>nmoxstudio</brandingToken>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <junit.version>6.1.1</junit.version>
        <mockito.version>5.23.0</mockito.version>
        <assertj.version>3.27.7</assertj.version>
    </properties>
</project>

<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.nmox</groupId>
    <artifactId>NMOX-Studio-parent</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>NMOX-Studio-parent</name>

    <repositories>
        <repository>
            <id>netbeans</id>
            <name>NetBeans</name>
            <url>https://netbeans.osuosl.org/content/repositories/releases/</url>
        </repository>
    </repositories>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.netbeans.utilities</groupId>
                    <artifactId>nbm-maven-plugin</artifactId>
                    <version>14.5</version>
                    <extensions>true</extensions>
                    <configuration>
                        <brandingToken>${brandingToken}</brandingToken>
                        <cluster>${brandingToken}</cluster>
                        <!-- Module spec versions track the product release train
                             (ledger 20). nbm:manifest derives the spec version
                             from the pom version (1.0-SNAPSHOT -> 1.0, frozen
                             since v0.1) UNLESS the source manifest already
                             carries the entry (conditionallyAddAttribute) — so
                             each module's src/main/nbm/manifest.mf declares
                             OpenIDE-Module-Specification-Version: ${spec.version}
                             and the filter-nbm-source-manifest execution below
                             interpolates it into target/nbm-manifest/manifest.mf,
                             which this points at. (The jar-plugin manifestEntries
                             route does NOT work: maven-archiver lets the
                             <manifestFile> win over configured entries — tested.)
                             Because the reactor packages each module before its
                             dependents' nbm:manifest runs, downstream modules
                             pick the version up into their generated
                             Module-Dependencies ("core > 1.47.0"), so a module
                             jar dropped into an older install refuses to load
                             instead of throwing LinkageError at call time
                             (ledger 30). Pinned by SpecVersionGateTest. -->
                        <sourceManifestFile>${project.build.directory}/nbm-manifest/manifest.mf</sourceManifestFile>
                        <!-- Every NBM embeds the license so the Plugin
                             Manager's install dialog shows real terms
                             instead of "License terms: Unknown" (each
                             module sits one level below the repo root). -->
                        <licenseName>MIT License</licenseName>
                        <licenseFile>../LICENSE</licenseFile>
                        <!-- The update-center catalog is built by
                             scripts/build-update-site.sh (nbm:autoupdate).
                             Note for future readers: the mojo's
                             updateSiteIncludes filter only applies when the
                             goal runs on an nbm-application project; the
                             root-aggregator path walks
                             session.getAllProjects() unfiltered (and ignores
                             -pl exclusions - verified live), so the script
                             prunes the never-shipped NMOX-Studio-sample from
                             the generated catalog itself. -->
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.15.0</version>
                    <configuration>
                        <source>${maven.compiler.source}</source>
                        <target>${maven.compiler.target}</target>
                        <release>${maven.compiler.target}</release>
                        <encoding>${project.build.sourceEncoding}</encoding>
                        <showWarnings>true</showWarnings>
                        <showDeprecation>true</showDeprecation>
                        <compilerArgs>
                            <arg>-Xlint:all</arg>
                            <arg>-Xlint:-processing</arg>
                            <!-- JDK 23+ defaults to -proc:none; NetBeans annotations
                                 (@TopComponent.Registration, @ServiceProvider, @Messages)
                                 need processing to generate layer/service registrations -->
                            <arg>-proc:full</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.5.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.6</version>
                <configuration>
                    <useModulePath>false</useModulePath>
                    <!-- The tests exercise the NetBeans platform (NbPreferences,
                         IOProvider, the filesystems URL machinery), which reflects
                         into java.base to install stream handlers — the same reason
                         the shipped IDE opens these in nmoxstudio.conf. Without a
                         matching test-JVM open, a JDK-21 fork that happens to reach
                         that init first throws InaccessibleObjectException; give the
                         test JVM the product's own java.base opens so it never can.
                         @{argLine} keeps JaCoCo's agent (it sets that property). -->
                    <argLine>@{argLine}
                        --add-opens=java.base/java.net=ALL-UNNAMED
                        --add-opens=java.base/java.lang=ALL-UNNAMED
                        --add-opens=java.base/java.lang.reflect=ALL-UNNAMED
                        --add-opens=java.base/java.io=ALL-UNNAMED
                        --add-opens=java.base/java.security=ALL-UNNAMED
                        --add-opens=java.base/java.util=ALL-UNNAMED</argLine>
                    <!-- Run the unit suite headless so it matches CI and never
                         pops a real Swing dialog (e.g. a workspace-trust prompt)
                         onto the developer's screen mid-build. -->
                    <systemPropertyVariables>
                        <java.awt.headless>true</java.awt.headless>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
            </plugins>
        </pluginManagement>
        <plugins>
            <plugin>
                <groupId>org.apache.netbeans.utilities</groupId>
                <artifactId>nbm-maven-plugin</artifactId>
                <extensions>true</extensions>
            </plugin>
            <!-- Interpolates ${spec.version} into each module's
                 src/main/nbm/manifest.mf (see the nbm-maven-plugin
                 pluginManagement comment). Runs in every child module;
                 modules without a src/main/nbm dir (application, the root)
                 skip with a warning — harmless. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <id>filter-nbm-source-manifest</id>
                        <phase>process-sources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.directory}/nbm-manifest</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.basedir}/src/main/nbm</directory>
                                    <includes>
                                        <include>manifest.mf</include>
                                    </includes>
                                    <filtering>true</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <!-- Static analysis: bytecode-based, so it runs after compile and
                 never interferes with the load-bearing -proc:full annotation
                 processing. Bound to verify, so CI's `mvn -B verify` gates on
                 it. Tuned to high-confidence correctness via the exclude filter. -->
            <plugin>
                <groupId>com.github.spotbugs</groupId>
                <artifactId>spotbugs-maven-plugin</artifactId>
                <version>4.10.3.0</version>
                <configuration>
                    <effort>Max</effort>
                    <threshold>Medium</threshold>
                    <failOnError>true</failOnError>
                    <excludeFilterFile>${maven.multiModuleProjectDirectory}/config/spotbugs-exclude.xml</excludeFilterFile>
                    <!-- security detectors: command injection, path traversal,
                         SSRF, weak crypto/random, XXE — the threat surface of an
                         IDE that spawns processes, calls cloud APIs and parses
                         untrusted files -->
                    <plugins>
                        <plugin>
                            <groupId>com.h3xstream.findsecbugs</groupId>
                            <artifactId>findsecbugs-plugin</artifactId>
                            <version>1.14.0</version>
                        </plugin>
                    </plugins>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!-- Coverage measurement, wired into the test run. -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.15</version>
                <!--
                  Coverage is measured on the TESTABLE surface. These classes are
                  pure Swing rendering/layout/event-wiring with no branchable
                  business logic — they cannot be unit-tested without a live
                  windowing system, and the real logic they delegate to lives in
                  service/model classes that ARE tested. Excluding them at the
                  instrumentation level keeps both the report and the coverage
                  floor honest: every name here is a deliberate, reviewed
                  exclusion (mirrors config/spotbugs-exclude.xml's discipline),
                  not a way to dodge a number. Widgets (Knob/Led/VuMeter/…) are
                  NOT excluded — their model logic is tested; only their paint()
                  stays uncovered, absorbed by the bundle floor.
                -->
                <configuration>
                    <excludes>
                        <!-- Dockable windows and modal dialogs (NetBeans window system) -->
                        <exclude>**/*TopComponent.class</exclude>
                        <exclude>**/*TopComponent$*.class</exclude>
                        <exclude>**/*Dialog.class</exclude>
                        <exclude>**/*Dialog$*.class</exclude>
                        <!-- core: first-run editor-theme installer (FontColorSettings glue) -->
                        <exclude>**/TerminalPhosphor.class</exclude>
                        <!-- editor: Navigator tree panel + LSP status table panel -->
                        <exclude>**/StructureNavigatorPanel*.class</exclude>
                        <exclude>**/LanguageServersPanel*.class</exclude>
                        <!-- tools: New Web Project wizard visual + iterator glue -->
                        <exclude>**/WebProjectWizardPanelVisual*.class</exclude>
                        <exclude>**/WebProjectWizardIterator*.class</exclude>
                        <!-- rack: the rack canvas, file tree, and palette list + renderer -->
                        <exclude>**/RackPanel.class</exclude>
                        <exclude>**/RackPanel$*.class</exclude>
                        <exclude>**/FileTreePanel*.class</exclude>
                        <exclude>**/PalettePanel*.class</exclude>
                        <!-- infra: property sheet, node-graph canvas, palette cell renderer -->
                        <exclude>**/PropertyPanel*.class</exclude>
                        <exclude>**/FlowCanvas*.class</exclude>
                        <exclude>**/InfraPalette$Renderer.class</exclude>
                        <!-- ui: main window shell + welcome launchpad screen -->
                        <exclude>**/MainWindow*.class</exclude>
                        <exclude>**/WelcomeScreen*.class</exclude>
                        <!-- ui: menu actions that only open a dialog/file-chooser and
                             delegate to logic tested in rack (PwaKit/Experiments/
                             EnvironmentDoctor are rack classes with their own tests).
                             These seven carry no testable branch of their own. The
                             actions that DO hold ui-resident logic (StandardsKitAction's
                             validate gate, NewLearningSpaceAction/SwitchProjectAction's
                             filter predicates, GeneralOptionsPanelController, UpdateCheck)
                             are kept and tested. -->
                        <exclude>**/ui/actions/PwaKitAction*.class</exclude>
                        <exclude>**/ui/actions/ManageExperimentsAction*.class</exclude>
                        <exclude>**/ui/actions/EnvironmentDoctorAction*.class</exclude>
                        <exclude>**/ui/actions/NewExperimentAction*.class</exclude>
                        <exclude>**/ui/actions/OpenFileAction*.class</exclude>
                        <exclude>**/ui/actions/OpenFolderAction*.class</exclude>
                        <exclude>**/ui/actions/NewProjectAction*.class</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <modules>
        <module>branding</module>
        <module>core</module>
        <module>ui</module>
        <module>editor</module>
        <module>project</module>
        <module>tools</module>
        <module>rack</module>
        <module>infra</module>
        <module>apiclient</module>
        <module>dbstudio</module>
        <module>web3</module>
        <module>application</module>
        <module>NMOX-Studio-sample</module>
    </modules>

    <properties>
        <netbeans.version>RELEASE300</netbeans.version>
        <brandingToken>nmoxstudio</brandingToken>
        <!-- Empty default so surefire's @{argLine} resolves even when JaCoCo's
             prepare-agent is skipped (e.g. -Djacoco.skip=true); when JaCoCo
             runs it overrides this with its -javaagent line. -->
        <argLine></argLine>
        <!-- The product version the module manifests carry as their
             OpenIDE-Module-Specification-Version (see the nbm-maven-plugin
             pluginManagement entry for the mechanism). Committed value = the
             release train this tree is heading toward; the release workflow
             stamps the tag's version over it (alongside branding's
             currentVersion, same step). Bump it when opening a new release
             sprint. -->
        <spec.version>1.74.0</spec.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <junit.version>6.1.2</junit.version>
        <mockito.version>5.23.0</mockito.version>
        <assertj.version>3.27.7</assertj.version>
        <!-- org.json rides in 8 separate module copies on purpose (module
             classloaders make a shared wrapper ClassCastException territory —
             ledger items 3 and 23); the copies STAY. This single property only
             centralizes the VERSION STRING so Dependabot bumps all eight in one
             PR. Every module pom references ${orgjson.version}. -->
        <orgjson.version>20260522</orgjson.version>
    </properties>

    <profiles>
        <!--
          NBM signing (ledger 21 tail). Off by default: no keystore, no
          signing, and the Plugin Manager shows its unsigned-plugin dialog on
          install — the historical behavior, so a normal build is unchanged.

          Activated only when -Dnbm.keystore=<path> is passed, which the
          release workflow does exactly when the NBM_SIGNING_* secrets are
          present (it decodes the keystore from a base64 secret first). Then
          every module's `nbm` goal signs its jar, and the update-center
          catalog carries signed NBMs. The property is set for the whole
          reactor, so this profile activates in every module.

          Generate a keystore and wire the three GitHub secrets per
          docs/engineering/nbm-signing.md.
        -->
        <profile>
            <id>sign-nbms</id>
            <activation>
                <property>
                    <name>nbm.keystore</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.netbeans.utilities</groupId>
                        <artifactId>nbm-maven-plugin</artifactId>
                        <configuration>
                            <keystore>${nbm.keystore}</keystore>
                            <keystorealias>${nbm.keystorealias}</keystorealias>
                            <keystorepassword>${nbm.keystorepass}</keystorepassword>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>

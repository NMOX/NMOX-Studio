<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Quick Search (Cmd+I) over the saved API requests: name, method,
         or URL, Enter jumps to it in API Studio. -->
    <folder name="QuickSearch">
        <folder name="ApiStudio">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.apiclient.search.Bundle"/>
            <!-- 325: infra's category holds 320, Databases 330, Contracts 340 -->
            <attr name="position" intvalue="325"/>
            <file name="org-nmox-studio-apiclient-search-ApiRequestSearchProvider.instance"/>
        </folder>
    </folder>
    <!-- Menu accelerators come from Keymaps-profile shadows, not from
         Shortcuts/ registrations (the v1.38.1 finding, debt #28): without
         this the Window menu shows "API Studio" with no ⌥⌘8 beside it.
         Same action as the Shortcuts/DA-8 binding on the TopComponent —
         behavior is unchanged, the chord just becomes discoverable. The
         chord is audited free of platform claims by WindowShortcutsTest,
         which also pins this shadow against the registration. -->
    <folder name="Keymaps">
        <folder name="NetBeans">
            <file name="DA-8.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-apiclient-ui-ApiClientTopComponent.instance"/>
            </file>
        </folder>
    </folder>
</filesystem>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Quick Search (Cmd+I) over the saved API requests: name, method,
         or URL, Enter jumps to it in API Studio. -->
    <folder name="QuickSearch">
        <folder name="ApiStudio">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.apiclient.search.Bundle"/>
            <!-- 325: infra's category holds 320, Databases 330, Contracts 340 -->
            <attr name="position" intvalue="325"/>
            <file name="org-nmox-studio-apiclient-search-ApiRequestSearchProvider.instance"/>
        </folder>
    </folder>
</filesystem>

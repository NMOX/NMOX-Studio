<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN"
        "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Quick Search (Cmd+I) over the database workspace: connection
         names, engines, hosts, and already-discovered tables; Enter
         jumps to the hit in DB Studio. Window-system entries ride
         annotations on the TopComponent. -->
    <folder name="QuickSearch">
        <folder name="Databases">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.dbstudio.search.Bundle"/>
            <attr name="position" intvalue="330"/>
            <file name="org-nmox-studio-dbstudio-search-DbSearchProvider.instance"/>
        </folder>
    </folder>
    <!-- Menu accelerators come from Keymaps-profile shadows, not from
         Shortcuts/ registrations (the v1.38.1 finding, debt #28): without
         this the Window menu shows "DB Studio" with no ⌥⌘7 beside it.
         Same action as the Shortcuts/DA-7 binding on the TopComponent —
         behavior is unchanged, the chord just becomes discoverable. The
         chord is audited free of platform claims by WindowShortcutsTest,
         which also pins this shadow against the registration. -->
    <folder name="Keymaps">
        <folder name="NetBeans">
            <file name="DA-7.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-dbstudio-ui-DbStudioTopComponent.instance"/>
            </file>
        </folder>
    </folder>
</filesystem>

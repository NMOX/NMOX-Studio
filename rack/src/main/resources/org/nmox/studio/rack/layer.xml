<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Quick Search (Cmd+I) providers: recent projects and the device
         catalog. The platform contributes Actions/Files/Recent Files;
         these make the rack itself searchable. -->
    <folder name="QuickSearch">
        <!-- The platform's projectui module already defines the Projects
             category (position 100, its own bundle). Contribute ONLY the
             provider instance: re-declaring position/localizingBundle here
             made two modules fight over the same folder's attributes with
             nondeterministic resolution. -->
        <folder name="Projects">
            <file name="org-nmox-studio-rack-search-RecentProjectSearchProvider.instance"/>
        </folder>
        <!-- Block Studio (v1.79.0, the studio-law parity sprint): type
             "blocks" or the component's tag, Enter opens the studio.
             Position 350 audited free (310 rack, 320 infra, 330 db,
             340 web3, 710 ui). -->
        <folder name="BlockStudio">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.rack.blockstudio.search.Bundle"/>
            <attr name="position" intvalue="350"/>
            <file name="org-nmox-studio-rack-blockstudio-search-BlockSearchProvider.instance"/>
        </folder>
        <!-- 310, not 300: the platform's jumpto GoToType sits at 300. -->
        <folder name="Rack">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.rack.search.Bundle"/>
            <attr name="position" intvalue="310"/>
            <file name="org-nmox-studio-rack-search-DeviceSearchProvider.instance"/>
        </folder>
        <!-- What is serving right now: live URLs from the ServingRegistry,
             ahead of the device catalog because a running server is the
             more urgent answer to "vite" than racking a new device. -->
        <folder name="LiveServers">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.rack.search.Bundle"/>
            <attr name="position" intvalue="275"/>
            <file name="org-nmox-studio-rack-search-LiveServerSearchProvider.instance"/>
        </folder>
    </folder>
</filesystem>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Quick Search (Cmd+I): make the current infra design searchable by
         node name or kind. Enter jumps the designer to the node. -->
    <folder name="QuickSearch">
        <folder name="Infra">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.infra.search.Bundle"/>
            <attr name="position" intvalue="320"/>
            <file name="org-nmox-studio-infra-search-InfraNodeSearchProvider.instance"/>
        </folder>
    </folder>
    <!-- Menu accelerators come from Keymaps-profile shadows, not from
         Shortcuts/ registrations (the v1.38.1 finding, debt #28): without
         this the Window menu shows "Infra Designer" with no ⌥⌘9 beside
         it. Same action as the Shortcuts/DA-9 binding on the TopComponent
         — behavior is unchanged, the chord just becomes discoverable. The
         chord is audited free of platform claims by WindowShortcutsTest,
         which also pins this shadow against the registration. -->
    <folder name="Keymaps">
        <folder name="NetBeans">
            <file name="DA-9.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-infra-InfraDesignerTopComponent.instance"/>
            </file>
        </folder>
    </folder>
</filesystem>

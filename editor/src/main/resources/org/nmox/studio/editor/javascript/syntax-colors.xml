<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE fontscolors PUBLIC "-//NetBeans//DTD Editor Fonts and Colors settings 1.1//EN" "http://www.netbeans.org/dtds/EditorFontsColors-1_1.dtd">

<!-- NMOX Phosphor: the 80s-terminal-but-modern palette. Explicit neon
     colors tuned for the dark theme; every entry keeps a `default`
     fallback so light profiles inherit something sane. -->
<fontscolors>
    <fontcolor name="keyword"             foreColor="ff6ac1" default="keyword"/>
    <fontcolor name="string"              foreColor="5af78e" default="string"/>
    <fontcolor name="template"            foreColor="5af78e" default="string"/>
    <fontcolor name="template-expression" foreColor="ff9f43" default="identifier"/>
    <fontcolor name="number"              foreColor="f3f99d" default="number"/>
    <fontcolor name="boolean"             foreColor="ff9f43" default="keyword"/>
    <fontcolor name="null"                foreColor="ff9f43" default="keyword"/>
    <fontcolor name="undefined"           foreColor="ff9f43" default="keyword"/>
    <fontcolor name="regex"               foreColor="ff5c57" default="string"/>
    <fontcolor name="identifier"          foreColor="e6e7eb" default="identifier"/>
    <fontcolor name="operator"            foreColor="9aedfe" default="operator"/>
    <fontcolor name="delimiter"           foreColor="b2b6be" default="separator"/>
    <fontcolor name="comment"             foreColor="6e7b8b" default="comment"/>
    <fontcolor name="whitespace"          default="whitespace"/>
    <fontcolor name="error"               foreColor="ff5c57" waveUnderlined="ff5c57" default="error"/>
</fontscolors>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- JavaScript MIME type registration lives on JavaScriptDataObject's
         @MIMEResolver.ExtensionRegistration (js/mjs/jsx -> text/javascript,
         position 100). A second layer-based resolver here was redundant and
         triggered the "ineffective registration, use @MIMEResolver" warning
         (NB bug #191777), so it was removed. -->

    <!-- The JavaScript loader's context-menu actions live on
         JavaScriptDataObject's @ActionReferences (the generated layer),
         which carry the complete standard set with unique positions.
         This module layer loads BEFORE the generated layer, so any
         hand-written Loaders/text/javascript shadows here would win
         attribute merges and collide with the annotation positions —
         keep loader wiring on the annotations only. -->

    <folder name="Editors">
        <!-- The IDE always runs the FlatLaf Dark look and feel (forced in
             nmoxstudio.conf), but the editor's color profile is a separate
             switch: it defaults to the light "NetBeans" profile and is only
             flipped by the Options->Appearance panel, which we bypass. Flip
             it here so every editor uses the platform's FlatLafDark profile
             (and our Phosphor palettes registered under it) instead of
             light-profile colors on a dark IDE. A user's explicit choice in
             Tools->Options still wins: that writes this same attribute into
             the userdir's writable layer, which shadows this one.
             The value is the profile's DISPLAY name ("FlatLaf Dark", from
             the flatlaf module's bundle), not its folder name: the settings
             storage validates the attribute against display names. -->
        <attr name="currentFontColorProfile" stringvalue="FlatLaf Dark"/>
        <folder name="text">
            <!-- The platform's markdown module wires the spellchecker's
                 whole-file PlainTokenListProvider to text/markdown, which flags
                 every identifier in fenced/inline code as a typo. Our
                 MarkdownSpellTokenListProvider (prose-only) replaces it; hide
                 the plain one so the two are never combined. -->
            <folder name="markdown">
                <folder name="TokenListProvider">
                    <file name="org-netbeans-modules-spellchecker-plain-PlainTokenListProvider.instance_hidden"/>
                </folder>
            </folder>
            <!-- Lexer language bindings + token coloring. The language.instance
                 entries are what make syntax highlighting actually happen: they
                 hand the editor infrastructure our Language for each MIME type.
                 The text/textmate pseudo-mime carries colorings for ALL TextMate
                 grammars; the platform only fills its "NetBeans" profile, so the
                 dark profile gets the NMOX Phosphor palette here. -->
            <folder name="textmate">
                <folder name="FontsColors">
                    <folder name="FlatLafDark">
                        <folder name="Defaults">
                            <file name="textmate-phosphor-colors.xml" url="grammars/textmate-phosphor-colors.xml"/>
                        </folder>
                    </folder>
                </folder>
            </folder>
            <folder name="javascript">
                <folder name="CodeTemplates">
                    <folder name="Defaults">
                        <file name="codetemplates.xml" url="javascript/codetemplates.xml"/>
                    </folder>
                </folder>
                <file name="language.instance">
                    <attr name="instanceCreate" methodvalue="org.nmox.studio.editor.javascript.JavaScriptTokenId.language"/>
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                </file>
                <file name="DAPBreakpoints.instance">
                    <attr name="instanceCreate" methodvalue="org.netbeans.modules.lsp.client.debugger.api.RegisterDAPBreakpoints.newInstance"/>
                </file>
                <!-- Phosphor is a dark palette: it belongs only to the dark
                     profile. Mapping it under "NetBeans" (the light profile)
                     painted pale-on-white JS whenever that profile was
                     active. -->
                <folder name="FontsColors">
                    <folder name="FlatLafDark">
                        <folder name="Defaults">
                            <file name="FontsColors.xml" url="javascript/syntax-colors.xml"/>
                        </folder>
                    </folder>
                </folder>
            </folder>
            <folder name="typescript">
                <folder name="CodeTemplates">
                    <folder name="Defaults">
                        <file name="codetemplates.xml" url="javascript/codetemplates.xml"/>
                    </folder>
                </folder>
                <file name="language.instance">
                    <attr name="instanceCreate" methodvalue="org.nmox.studio.editor.typescript.TypeScriptLanguage.language"/>
                    <attr name="instanceOf" stringvalue="org.netbeans.api.lexer.Language"/>
                </file>
                <file name="DAPBreakpoints.instance">
                    <attr name="instanceCreate" methodvalue="org.netbeans.modules.lsp.client.debugger.api.RegisterDAPBreakpoints.newInstance"/>
                </file>
                <!-- dark palette, dark profile only — see the javascript
                     folder above -->
                <folder name="FontsColors">
                    <folder name="FlatLafDark">
                        <folder name="Defaults">
                            <file name="FontsColors.xml" url="javascript/syntax-colors.xml"/>
                        </folder>
                    </folder>
                </folder>
            </folder>
            <folder name="x-python">
                <file name="DAPBreakpoints.instance">
                    <attr name="instanceCreate" methodvalue="org.netbeans.modules.lsp.client.debugger.api.RegisterDAPBreakpoints.newInstance"/>
                </file>
            </folder>
            <folder name="x-go">
                <file name="DAPBreakpoints.instance">
                    <attr name="instanceCreate" methodvalue="org.netbeans.modules.lsp.client.debugger.api.RegisterDAPBreakpoints.newInstance"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <folder name="Menu">
        <folder name="File">
            <!-- The platform ships its own Open File and New Project menu
                 items; ours (OpenFileAction, NewProjectAction - wired to the
                 rack-aware project dialog) replace them. One entry each. -->
            <file name="org-netbeans-modules-openfile-OpenFileAction.shadow_hidden"/>
            <file name="org-netbeans-modules-project-ui-NewProject.shadow_hidden"/>
        </folder>
        <!-- The Refactor menu is a Java-IDE organ: our languages ride
             TextMate + LSP, where rename lives on the editor context menu.
             An always-empty top-level menu reads as broken. -->
        <file name="Refactoring_hidden"/>
    </folder>
    <folder name="Shortcuts">
        <!-- free Cmd+Shift+N from the hidden platform wizard so it
             reaches our New Project action instead -->
        <file name="DS-N.shadow_hidden"/>
    </folder>
    <!-- The Quick Search widget in the toolbar: the platform ships the
         action (Cmd+I) and the Actions/Files providers; this puts the
         search field where every modern tool has one. On macOS the
         applemenu module registers the same toolbar (folder position
         710) and the two merge; off-mac this entry is load-bearing, so
         it carries the same position and a real display name for the
         View → Toolbars menu instead of the raw folder name. -->
    <folder name="Toolbars">
        <folder name="QuickSearch">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.ui.resources.Bundle"/>
            <attr name="position" intvalue="710"/>
            <file name="org-netbeans-modules-quicksearch-QuickSearchAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Edit/org-netbeans-modules-quicksearch-QuickSearchAction.instance"/>
            </file>
        </folder>
    </folder>
    <!-- The update center (ledger 21): the platform's autoupdate stack
         (services/ui/cli) ships in our cluster but had no provider to
         read, so Tools > Plugins showed an empty Available tab. This
         entry feeds it from GitHub releases. The shape is the classic
         AutoupdateCatalogFactory registration (attribute names verified
         against the shipped autoupdate-services jar: url, enabled,
         category, trusted).
         - The catalog URL rides /releases/latest/download/, GitHub's
           stable redirect to the newest release's asset - the app never
           needs a code change to see the next version.
         - Inside the catalog every NBM URL is ABSOLUTE, pinned to its
           own release tag (scripts/build-update-site.sh): the platform
           resolves relative URLs against the pre-redirect catalog URL,
           so relative ones would let a cached old catalog download
           newer "latest" NBMs and fail their SHA-512 digests.
         - trusted: our own release channel over HTTPS; the NBMs are
           unsigned (signing stays manual, see the debt ledger), so
           without this every install shows a scare dialog.
         - No fetch happens at boot: the factory only stores these
           attributes; the platform checks the URL on user action or on
           its own schedule (default EVERY_WEEK, first check 500ms after
           the UI is ready - decompiled AutoupdateCheckScheduler).
         Pinned by UpdateCenterTest. -->
    <folder name="Services">
        <folder name="AutoupdateType">
            <file name="org-nmox-studio-update-center.instance">
                <attr name="url" stringvalue="https://github.com/NMOX/NMOX-Studio/releases/latest/download/updates.xml"/>
                <attr name="displayName" bundlevalue="org.nmox.studio.ui.resources.Bundle#Services/AutoupdateType/org-nmox-studio-update-center.instance"/>
                <attr name="enabled" boolvalue="true"/>
                <attr name="trusted" boolvalue="true"/>
                <attr name="category" stringvalue="STANDARD"/>
                <attr name="instanceCreate" methodvalue="org.netbeans.modules.autoupdate.updateprovider.AutoupdateCatalogFactory.createUpdateProvider"/>
                <attr name="instanceOf" stringvalue="org.netbeans.spi.autoupdate.UpdateProvider"/>
            </file>
        </folder>
    </folder>
    <folder name="Keymaps">
        <folder name="NetBeans">
            <!-- jumpto's keymap profile grabs Cmd+O for "Go to Type" (a
                 Java-type dialog), overriding our Shortcuts/D-O Open File
                 binding - profile entries outrank Shortcuts. Mask it so
                 Cmd+O opens files, like every other editor on earth. -->
            <file name="D-O.shadow_hidden"/>
            <!-- Menu accelerators come from Keymaps-profile shadows, not
                 from Shortcuts/ registrations (the v1.38.1 finding, debt
                 #28): without these the Window menu shows "Task Rack" /
                 "Docker Panel" (and File shows "Open Folder…") with no
                 chord beside them. Each shadow points at the SAME action
                 its Shortcuts binding invokes — behavior is unchanged,
                 the chord just becomes discoverable. The rack windows'
                 shadows live here beside the D-O mask (the system
                 filesystem merges every module's layer, so placement is
                 free) because ui owns the advertised-shortcut contract:
                 the Welcome labels and WindowShortcutsTest, which pins
                 each shadow against its registration. -->
            <file name="D-9.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-rack-RackTopComponent.instance"/>
            </file>
            <file name="D-8.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-rack-docker-DockerPanelTopComponent.instance"/>
            </file>
            <file name="DA-5.shadow">
                <attr name="originalFile" stringvalue="Actions/Window/org-nmox-studio-rack-blockstudio-BlockStudioTopComponent.instance"/>
            </file>
            <file name="DA-O.shadow">
                <attr name="originalFile" stringvalue="Actions/File/org-nmox-studio-ui-actions-OpenFolderAction.instance"/>
            </file>
        </folder>
    </folder>
</filesystem>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "https://netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <folder name="Menu">
        <folder name="File">
            <!-- The platform ships its own Open File and New Project menu
                 items; ours (OpenFileAction, NewProjectAction - wired to the
                 rack-aware project dialog) replace them. One entry each. -->
            <file name="org-netbeans-modules-openfile-OpenFileAction.shadow_hidden"/>
            <file name="org-netbeans-modules-project-ui-NewProject.shadow_hidden"/>
        </folder>
        <!-- The Refactor menu is a Java-IDE organ: our languages ride
             TextMate + LSP, where rename lives on the editor context menu.
             An always-empty top-level menu reads as broken. -->
        <file name="Refactoring_hidden"/>
    </folder>
    <folder name="Shortcuts">
        <!-- free Cmd+Shift+N from the hidden platform wizard so it
             reaches our New Project action instead -->
        <file name="DS-N.shadow_hidden"/>
    </folder>
    <!-- The Quick Search widget in the toolbar: the platform ships the
         action (Cmd+I) and the Actions/Files providers; this puts the
         search field where every modern tool has one. On macOS the
         applemenu module registers the same toolbar (folder position
         710) and the two merge; off-mac this entry is load-bearing, so
         it carries the same position and a real display name for the
         View → Toolbars menu instead of the raw folder name. -->
    <folder name="Toolbars">
        <folder name="QuickSearch">
            <attr name="SystemFileSystem.localizingBundle" stringvalue="org.nmox.studio.ui.resources.Bundle"/>
            <attr name="position" intvalue="710"/>
            <file name="org-netbeans-modules-quicksearch-QuickSearchAction.shadow">
                <attr name="originalFile" stringvalue="Actions/Edit/org-netbeans-modules-quicksearch-QuickSearchAction.instance"/>
            </file>
        </folder>
    </folder>
    <folder name="Keymaps">
        <folder name="NetBeans">
            <!-- jumpto's keymap profile grabs Cmd+O for "Go to Type" (a
                 Java-type dialog), overriding our Shortcuts/D-O Open File
                 binding - profile entries outrank Shortcuts. Mask it so
                 Cmd+O opens files, like every other editor on earth. -->
            <file name="D-O.shadow_hidden"/>
        </folder>
    </folder>
</filesystem>
